#!/usr/bin/env bash
# Print an updated ``url`` + ``sha256`` block for the flow-cli formula,
# given a new version tag. Run *after* the GitHub release tarball is
# available (e.g. once CI has pushed the tag).
#
# Usage:
#   dist/homebrew-tap/bin/release-formula 0.1.1
set -euo pipefail

if [[ $# -ne 1 ]]; then
  echo "usage: $0 <version>" >&2
  exit 2
fi
VERSION="$1"
TARBALL_URL="https://github.com/angleto/flow/archive/refs/tags/cli-v${VERSION}.tar.gz"

tmp=$(mktemp)
trap 'rm -f "$tmp"' EXIT

echo "Fetching $TARBALL_URL ..." >&2
curl -fSL "$TARBALL_URL" -o "$tmp"

SHA=$(shasum -a 256 "$tmp" | awk '{print $1}')

cat <<EOF
  url "$TARBALL_URL"
  sha256 "$SHA"
EOF
